{
  "manifest_version": 3,
  "name": "域名探测器",
  "description": "分析网页第三方域名，识别非中国域名，用于防火墙白名单配置。",
  "version": "1.1.0",
  "permissions": [
    "webRequest",
    "webNavigation",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "域名探测器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
